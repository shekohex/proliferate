{
	"compilerOptions": {
		"baseUrl": ".",
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"types": ["node"],
		"paths": {
			"@/*": ["./src"],
			"api/*": ["./src/*"],
			"utils/*": ["./src/utils/*"],
			"testHelpers/*": ["./testHelpers/*"]
		}
	},
	"include": ["**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
